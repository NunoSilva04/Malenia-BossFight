{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 10,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-debug-preset",
            "inherits": ["windows-base"],
            "binaryDir": "${sourceDir}/build/windows-ninja-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/Windows/Debug",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/bin/Windows/Debug",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/bin/Windows/Debug/static_libs"
            }
        },
        {
            "name": "windows-release-preset",
            "inherits": ["windows-base"],
            "binaryDir": "${sourceDir}/build/windows-ninja-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/Windows/Release",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/bin/Windows/Release",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/bin/Windows/Release/static_libs"
            }
        },

        {
            "name": "macos-base",
            "hidden": true,
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-debug-preset",
            "inherits": ["macos-base"],
            "binaryDir": "${sourceDir}/build/macos-ninja-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/MacOS/Debug",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/bin/MacOS/Debug",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/bin/MacOS/Debug/static_libs"
            }
        },
        {
            "name": "macos-release-preset",
            "inherits": ["macos-base"],
            "binaryDir": "${sourceDir}/build/macos-ninja-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/MacOS/Release",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/bin/MacOS/Release",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/bin/MacOS/Release/static_libs"
            }
        },

        {
            "name": "linux-base",
            "hidden": true,
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-debug-preset",
            "inherits": ["linux-base"],
            "binaryDir": "${sourceDir}/build/linux-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/Linux/Debug",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/bin/Linux/Debug",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/bin/Linux/Debug/static_libs"
            }
        },
        {
            "name": "linux-release-preset",
            "inherits": ["linux-base"],
            "binaryDir": "${sourceDir}/build/linux-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/bin/Linux/Release",
                "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/bin/Linux/Release",
                "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/bin/Linux/Release/static_libs"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-debug-build",
            "configurePreset": "windows-debug-preset",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-release-build",
            "configurePreset": "windows-release-preset",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "macos-debug-build",
            "configurePreset": "macos-debug-preset",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-release-build",
            "configurePreset": "macos-release-preset",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "linux-debug-build",
            "configurePreset": "linux-debug-preset",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-release-build",
            "configurePreset": "linux-release-preset",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        }
    ],

    "workflowPresets": [
        {
            "name": "windows-debug",
            "steps": [
                {"type": "configure", "name": "windows-debug-preset"},
                {"type": "build", "name": "windows-debug-build"}
            ]
        },
        {
            "name": "windows-release",
            "steps": [
                {"type": "configure", "name": "windows-release-preset"},
                {"type": "build", "name": "windows-release-build"}
            ]
        },
        {
            "name": "linux-debug",
            "steps": [
                {"type": "configure", "name": "linux-debug-preset"},
                {"type": "build", "name": "linux-debug-build"}
            ]
        },
        {
            "name": "linux-release",
            "steps": [
                {"type": "configure", "name": "linux-release-preset"},
                {"type": "build", "name": "linux-release-build"}
            ]
        },
        {
            "name": "macos-debug",
            "steps": [
                {"type": "configure", "name": "macos-debug-preset"},
                {"type": "build", "name": "macos-debug-build"}
            ]
        },
        {
            "name": "macos-release",
            "steps": [
                {"type": "configure", "name": "macos-release-preset"},
                {"type": "build", "name": "macos-release-build"}
            ]
        }
    ]
}